  "proxy_base_env_file": "../research-experiments/mac_proxy_candidates/2026-03-23_thwu1_mlx_proxy/mac_frontier_env.json",
  "proxy_target_bpb": 1.5,
  "proxy_external_process_patterns": [
    "scripts/run_mlx_proxy_experiment.py --experiment-dir mac_proxy_candidates/2026-03-23_thwu1_mlx_proxy"
  ],
  "auto_git_push": true,
  "git_remote_name": "origin",
  "auto_git_commit_prefix": "research-agent checkpoint"
}
